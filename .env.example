# ---------------------------------------------------------------------------
# Ballage Pet Concierge — environment variables
# Copy this file to `.env.local` for local dev, and set the same values in your
# host's dashboard (e.g. Vercel → Project → Settings → Environment Variables).
# ---------------------------------------------------------------------------

# REQUIRED for form emails to be delivered. Get a free key at https://resend.com
# Without it, submissions are accepted and logged server-side but NOT emailed.
RESEND_API_KEY=

# OPTIONAL — where form submissions are sent. Defaults to site.email in src/lib/site.ts
CONTACT_TO_EMAIL=

# OPTIONAL — the "from" sender. Must be a Resend-verified domain in production,
# e.g. "Ballage Pet Concierge <hello@ballagepetconcierge.com>".
# Defaults to Resend's test sender (onboarding@resend.dev), which only delivers
# to the email on your own Resend account — fine for initial testing.
CONTACT_FROM_EMAIL=
